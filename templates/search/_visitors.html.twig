<h2>{% trans %}Visitors{% endtrans %}</h2>
<div class="table-responsive">
    <table class="table table-hover">
        <thead>
	    <tr>
		{% if is_granted("ROLE_SUPER_ADMIN") %}
		    <th>{% trans %}Id{% endtrans %}</th>
		{% endif %}
                <th>{% trans %}Name{% endtrans %}</th>
                <th>{% trans %}Tag{% endtrans %}</th>
                <th>{% trans %}Check in{% endtrans %}</th>
                <th>{% trans %}actions{% endtrans %}</th>
	    </tr>
        </thead>
        <tbody>
	    {% for visitor in visitors %}
		<tr>
		    {% if is_granted('ROLE_SUPER_ADMIN') %}
			<td>{{ visitor.id }}</td>
		    {% endif %}
		    <td>{{ visitor.name|title }}</td>
		    <td>{{ visitor.tag }}</td>
		    <td>{{ visitor.checkInAt ? visitor.checkInAt|date('Y-m-d H:i:s') : '' }}</td>
		    <td class="d-flex flex-wrap">
			{% if tag is defined %}
			    <form method="post" action="{{ path('app_visitor_check_out', {'id': visitor.uuid, 'redirect_route': 'app_search_check_index', 'tag': tag}) }}" onsubmit="return confirm('{% trans %}Are you sure you want to check out?{% endtrans %}');">
				<input type="hidden" name="_token" value="{{ csrf_token('checkout' ~ visitor.id) }}">
				<button type="submit" class="btn btn-danger">{% trans %}Check out{% endtrans %}</button>
			    </form>
			{% elseif name is defined %}
			    <form method="post" action="{{ path('app_visitor_check_out', {'id': visitor.uuid, 'redirect_route': 'app_search_name_check_out', 'name': name}) }}" onsubmit="return confirm('{% trans %}Are you sure you want to check out?{% endtrans %}');">
				<input type="hidden" name="_token" value="{{ csrf_token('checkout' ~ visitor.id) }}">
				<button type="submit" class="btn btn-danger">{% trans %}Check out{% endtrans %}</button>
			    </form>
			{% else %}
			    <form method="post" action="{{ path('app_visitor_check_out', {'id': visitor.uuid, 'redirect_route': 'app_search_check_list_index'}) }}" onsubmit="return confirm('{% trans %}Are you sure you want to check out?{% endtrans %}');">
				<input type="hidden" name="_token" value="{{ csrf_token('checkout' ~ visitor.id) }}">
				<button type="submit" class="btn btn-danger">{% trans %}Check out{% endtrans %}</button>
			    </form>
			{% endif %}
			<div>
			    <a class="btn btn-link" href="{{ path('app_visitor_show', {'id': visitor.uuid}) }}">{% trans %}Show{% endtrans %}</a>
			</div>
			{% if is_granted('ROLE_SUPER_ADMIN') %}
			    <div>
				<a class="btn btn-secondary" href="{{ path('app_visitor_edit', {'id': visitor.uuid}) }}">{% trans %}Edit{% endtrans %}</a>
			    </div>
			{% endif %}
		    </td>
		</tr>
        {% else %}
		<tr>
		    <td colspan="5">{% trans %}no records found{% endtrans %}</td>
		</tr>
	    {% endfor %}
        </tbody>
    </table>
</div>
