{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <ol class="breadcrumb">
	<li class="breadcrumb-item"><a href="https://www.gob.mx"><i class="icon icon-home"></i></a></li>
	<li class="breadcrumb-item"><a href="{{ path('app_index') }}">{% trans %}Begin{% endtrans %}</a></li>
	<li class="breadcrumb-item"><a href="{{ path('app_search_index') }}">{% trans %}Search{% endtrans %}</a></li>
	{% if tag is defined %}
	    <li class="breadcrumb-item active" aria-current="page"><a href="{{ path('app_search_check_index', {'tag': tag}) }}">{{ title }}</a></li>
	{% elseif name is defined %}
	    <li class="breadcrumb-item active" aria-current="page"><a href="{{ path('app_search_name_check_out', {'name': name}) }}">{{ title }}</a></li>
	{% else %}
	    <li class="breadcrumb-item active" aria-current="page"><a href="{{ path('app_search_check_list_index') }}">{{ title }}</a></li>
	{% endif %}
    </ol>

    <h1>{{ title }}</h1>
    <hr class="red">

    {% for label, messages in app.flashes %}
	{% for message in messages %}
	    <div class="alert alert-{{ label }}">
		{{ message|trans }}
	    </div>
	{% endfor %}
    {% endfor %}

    <div>
	<p>
	    <ul class="nav nav-pills nav-fill flex-column flex-sm-row" id="nav-tab" role="tablist">
		<li class="flex-sm-fill text-sm-center nav-link active" id="nav-tab-01" data-bs-toggle="tab" href="#nav-01" role="tab" aria-controls="nav-01" aria-selected="true">{% trans %}Patients{% endtrans %}</li>
		<li class="flex-sm-fill text-sm-center nav-link" id="nav-tab-02" data-bs-toggle="tab" href="#nav-02" role="tab" aria-controls="nav-02" aria-selected="false">{% trans %}Visitors{% endtrans %}</li>
	    </ul>
	</p>
	<div class="tab-content" id="nav-tabContent">
	    <div class="tab-pane fade show active" id="nav-01" role="tabpanel" aria-labelledby="nav-tab-01">
		{{ include('search/_patients.html.twig') }}
	    </div>
	    <div class="tab-pane fade" id="nav-02" role="tabpanel" aria-labelledby="nav-tab-02">
		{{ include('search/_visitors.html.twig') }}
	    </div>
	</div>
    </div>
{% endblock %}
