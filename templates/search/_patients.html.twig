<h2>{% trans %}Patients{% endtrans %}</h2>
<div class="table-responsive">
    <table class="table table-hover">
        <thead>
	    <tr>
		{% if is_granted("ROLE_SUPER_ADMIN") %}
		    <th>{% trans %}Id{% endtrans %}</th>
		{% endif %}
                <th>{% trans %}File{% endtrans %}</th>
                <th>{% trans %}Name{% endtrans %}</th>
                <th>{% trans %}Tag{% endtrans %}</th>
                <th>{% trans %}Check in{% endtrans %}</th>
                <th>{% trans %}actions{% endtrans %}</th>
	    </tr>
        </thead>
        <tbody>
	    {% for attendance in patients %}
		<tr>
		    {% if is_granted("ROLE_SUPER_ADMIN") %}
			<td>{{ attendance.patient.id }}</td>
		    {% endif %}
		    <td>{{ attendance.patient.file }}</td>
		    <td>{{ attendance.patient.name|title }}</td>
		    <td>{{ attendance.tag }}</td>
		    <td>{{ attendance.checkInAt ? attendance.checkInAt|date('Y-m-d H:i:s') : '' }}</td>
		    <td class="d-flex flex-wrap">
			{% if tag is defined %}
			    <form method="post" action="{{ path('app_patient_check_out', {'id': attendance.patient.uuid, 'tag': tag}) }}" onsubmit="return confirm('{% trans %}Are you sure you want to check out?{% endtrans %}');">
				<input type="hidden" name="redirect_route" value="app_search_check_index">
				<input type="hidden" name="redirect_params[tag]" value="{{ tag }}">
				<button type="submit" class="btn btn-danger">{% trans %}Check out{% endtrans %}</button>
			    </form>
			{% elseif name is defined %}
			    <form method="post" action="{{ path('app_patient_check_out', {'id': attendance.patient.uuid}) }}" onsubmit="return confirm('{% trans %}Are you sure you want to check out?{% endtrans %}');">
				<input type="hidden" name="redirect_route" value="app_search_name_check_out">
				<input type="hidden" name="redirect_params[name]" value="{{ name }}">
				<button type="submit" class="btn btn-danger">{% trans %}Check out{% endtrans %}</button>
			    </form>
			{% else %}
			    <form method="post" action="{{ path('app_patient_check_out', {'id': attendance.patient.uuid}) }}" onsubmit="return confirm('{% trans %}Are you sure you want to check out?{% endtrans %}');">
				<input type="hidden" name="redirect_route" value="app_search_check_list_index">
				<button type="submit" class="btn btn-danger">{% trans %}Check out{% endtrans %}</button>
			    </form>
			{% endif %}
			<div>
			    <a class="btn btn-link" href="{{ path('app_patient_show', {'id': attendance.patient.uuid}) }}">{% trans %}Show{% endtrans %}</a>
			</div>
			{% if is_granted('ROLE_SUPER_ADMIN') %}
			    <div>
				<a class="btn btn-secondary" href="{{ path('app_patient_edit', {'id': attendance.patient.uuid}) }}">{% trans %}Edit{% endtrans %}</a>
			    </div>
			{% endif %}
		    </td>
		</tr>
        {% else %}
		<tr>
		    <td colspan="6">{% trans %}no records found{% endtrans %}</td>
		</tr>
	    {% endfor %}
        </tbody>
    </table>
</div>
