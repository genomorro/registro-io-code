{% extends 'base.html.twig' %}

{% block title %}{% trans %}Stakeholder index{% endtrans %}{% endblock %}

{% block body %}
    <ol class="breadcrumb">
	<li class="breadcrumb-item"><a href="https://www.gob.mx"><i class="icon icon-home"></i></a></li>
	<li class="breadcrumb-item"><a href="{{ path('app_index') }}">{% trans %}Begin{% endtrans %}</a></li>
	<li class="breadcrumb-item active" aria-current="page"><a href="{{ path('app_stakeholder_index') }}">{% trans %}Stakeholder{% endtrans %}</a></li>
    </ol>

    <h1>{% trans %}Stakeholder index{% endtrans %}</h1>
    <hr class="red">

    {% for label, messages in app.flashes %}
	{% for message in messages %}
	    <div class="alert alert-{{ label }}">
		{{ message|trans }}
	    </div>
	{% endfor %}
    {% endfor %}

    <div class="row">
	<div class="col-12 col-md-6 d-flex justify-content-start">
	    <form class="w-100" method="get" action="{{ path('app_stakeholder_index') }}">
		<div class="input-group mb-3">
		    <input type="text" name="filter" class="form-control input-sm w-75" placeholder="{% trans %}Search by Name or Tag{% endtrans %}" value="{{ app.request.query.get('filter') }}">
		    <button class="btn btn-sm btn-info" type="submit">
			<span class="icon-search" aria-hidden="true"></span>
		    </button>
		</div>
	    </form>
	</div>

	<div class="col-12 col-md-6 d-flex justify-content-md-end justify-content-start mt-2 mt-md-0">
	    Registros totales: {{ stakeholders.getTotalItemCount }}
	</div>
    </div>

    <div class="table-responsive">
	<table class="table table-hover">
            <thead>
		<tr>
		    {% if is_granted('ROLE_SUPER_ADMIN') %}
			<th scope="col">{{ knp_pagination_sortable(stakeholders, 'Id'|trans, 's.id') }}</th>
		    {% endif %}
                    <th scope="col">{{ knp_pagination_sortable(stakeholders, 'Name'|trans, 's.name') }}</th>
                    <th scope="col">{{ knp_pagination_sortable(stakeholders, 'Tag'|trans, 's.tag') }}</th>
                    <th scope="col">{{ knp_pagination_sortable(stakeholders, 'Company'|trans, 's.company') }}</th>
                    <th scope="col">{{ knp_pagination_sortable(stakeholders, 'Check in'|trans, 's.checkInAt') }}</th>
                    <th scope="col">{{ knp_pagination_sortable(stakeholders, 'Check out'|trans, 's.checkOutAt') }}</th>
                    <th>{% trans %}actions{% endtrans %}</th>
		</tr>
            </thead>
            <tbody>
		{% for stakeholder in stakeholders %}
		    <tr>
			{% if is_granted('ROLE_SUPER_ADMIN') %}
			    <td>{{ stakeholder.id }}</td>
			{% endif %}
			<td>{{ stakeholder.name|title }}</td>
			<td>{{ stakeholder.tag }}</td>
			<td>{{ stakeholder.company }}</td>
			<td>{{ stakeholder.checkInAt ? stakeholder.checkInAt|date('Y-m-d H:i:s') : '' }}</td>
			<td>
			    {% if stakeholder.checkOutAt %}
				{{ stakeholder.checkOutAt|date('Y-m-d H:i:s') }}
			    {% else %}
				<form method="post"
				      action="{{ path('app_stakeholder_check_out', {'id': stakeholder.uuid, 'redirect_route': 'app_stakeholder_index'}) }}"
				      data-controller="modal-confirm"
				      data-modal-confirm-message-value="{% trans %}Are you sure you want to check out?{% endtrans %}"
				      data-modal-confirm-title-value="{% trans %}Check out{% endtrans %}"
				      data-action="submit->modal-confirm#confirm">
				    <input type="hidden" name="_token" value="{{ csrf_token('checkout' ~ stakeholder.id) }}">
				    <button class="btn btn-sm btn-danger">{% trans %}Check out{% endtrans %}</button>
				</form>
			    {% endif %}
			</td>
			<td>
			    <a class="btn btn-link" href="{{ path('app_stakeholder_show', {'id': stakeholder.uuid}) }}">{% trans %}Show{% endtrans %}</a>
			    <a class="btn btn-secondary" href="{{ path('app_stakeholder_edit', {'id': stakeholder.uuid}) }}">{% trans %}Edit{% endtrans %}</a>
			</td>
		    </tr>
{% else %}
		    <tr>
			<td colspan="9">{% trans %}no records found{% endtrans %}</td>
		    </tr>
		{% endfor %}
            </tbody>
	</table>
    </div>

    <div class="navigation">
        {{ knp_pagination_render(stakeholders) }}
    </div>

    <a class="btn btn-primary" href="{{ path('app_stakeholder_new') }}">{% trans %}Create new{% endtrans %}</a>

    <div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
	<div class="modal-dialog">
	    <div class="modal-content">
		<div class="modal-header">
		    <h5 class="modal-title" id="confirmModalLabel" data-default-title="{% trans %}Confirmation{% endtrans %}">{% trans %}Confirmation{% endtrans %}</h5>
		    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
		</div>
		<div class="modal-body">
		    <!-- Message will be injected here -->
		</div>
		<div class="modal-footer">
		    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{% trans %}Cancel{% endtrans %}</button>
		    <button type="button" class="btn btn-primary btn-confirm">{% trans %}Confirm{% endtrans %}</button>
		</div>
	    </div>
	</div>
    </div>
{% endblock %}
